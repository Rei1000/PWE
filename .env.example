DATABASE_URL=
# Leer lassen für In-Memory (Dev/Test). Beispiele:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/app
# docker compose setzt DATABASE_URL automatisch (siehe README-docker.md)
API_URL=
ENV=development

# Externes Kommando — Adapterwahl (Default: simulation)
# EXTERNES_KOMMANDO_ADAPTER=simulation
# EXTERNES_KOMMANDO_ADAPTER=com
# SERIELL_PORT=/dev/ttyUSB0
# SERIELL_BAUDRATE=9600
# SERIELL_TIMEOUT_MS=3000
# COM-Modus erfordert: pip install ".[com]" (pyserial)
